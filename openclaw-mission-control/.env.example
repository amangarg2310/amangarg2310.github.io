# OpenClaw Mission Control — Environment Variables
#
# Copy this file to .env.local and fill in values.

# ──────────────────────────────────────────────────
# API URL (optional)
# ──────────────────────────────────────────────────
# When set, the frontend fetches from this URL instead of the
# built-in Next.js API routes. Use this to point at an external
# OpenClaw runtime or standalone backend.
#
# Leave unset for demo mode (uses built-in mock data via /api routes).
#
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ──────────────────────────────────────────────────
# OpenClaw Bridge — Local Data Access
# ──────────────────────────────────────────────────
# The bridge reads data directly from the local OpenClaw installation
# via CLI shell-out and on-disk .jsonl transcript files.
#
# When NOT configured, the dashboard runs in demo mode with mock data.
#
# State directory resolution order:
#   1. OPENCLAW_STATE_DIR (explicit path)
#   2. OPENCLAW_PROFILE → ~/.openclaw-<profile>
#   3. Default: ~/.openclaw
#
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_PROFILE=default
# OPENCLAW_CLI_PATH=openclaw

# ──────────────────────────────────────────────────
# Sync Interval (optional)
# ──────────────────────────────────────────────────
# How often (in ms) to poll via CLI. Default: 15000 (15s).
# Minimum: 5000 (5s).
#
# SYNC_INTERVAL_MS=15000

# ──────────────────────────────────────────────────
# Auth (optional — for future use)
# ──────────────────────────────────────────────────
# API_SECRET=your-secret-here
