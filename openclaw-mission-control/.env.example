# OpenClaw Mission Control — Environment Variables
#
# Copy this file to .env.local and fill in values.

# ──────────────────────────────────────────────────
# API URL (optional)
# ──────────────────────────────────────────────────
# When set, the frontend fetches from this URL instead of the
# built-in Next.js API routes. Use this to point at an external
# OpenClaw runtime or standalone backend.
#
# Leave unset for demo mode (uses built-in mock data via /api routes).
#
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ──────────────────────────────────────────────────
# OpenClaw Runtime (optional — for future adapter)
# ──────────────────────────────────────────────────
# URL of the OpenClaw runtime to pull live agent/run/task data from.
# The API routes will poll this and normalize into the dashboard schema.
#
# OPENCLAW_RUNTIME_URL=http://localhost:5555

# ──────────────────────────────────────────────────
# Auth (optional — for future use)
# ──────────────────────────────────────────────────
# API_SECRET=your-secret-here
